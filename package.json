{
  "name": "draftlens",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "DraftLens — transparent NFL Draft analytics platform.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "data:inventory": "python3 scripts/inventory_data.py",
    "data:extract": "python3 scripts/extract_text_blocks.py",
    "data:normalize": "python3 scripts/normalize_data.py",
    "data:build": "python3 scripts/normalize_data.py",
    "data:training": "python3 scripts/build_training_dataset.py",
    "data:all": "npm run data:inventory && npm run data:extract && npm run data:normalize && npm run data:training",
    "model:train": "python3 scripts/train_draftlens_model.py",
    "model:export": "python3 scripts/export_frontend_data.py",
    "model:all": "npm run model:train && npm run model:export",
    "pipeline": "npm run data:all && npm run model:all",
    "validate": "npm run typecheck && npm run build"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "~5.6.3",
    "vite": "^6.0.3"
  }
}
