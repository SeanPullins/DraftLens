{
  "dataDir": "~/Documents/Draftwebsiteinfo",
  "processedDir": "data/processed",
  "publicModelDir": "public/data/model",
  "docsDir": "docs",
  "modelVersion": "0.1.0",
  "draftClassRange": [2014, 2027],
  "latestCompletedDraft": 2026,
  "bronzeDir": "data/bronze",
  "goldDir": "data/gold",
  "fileTypes": ["csv", "tsv", "xlsx", "xls", "json", "ndjson", "parquet", "duckdb", "txt", "md", "log", "html"],
  "textFileTypes": ["txt", "md", "log", "html"],
  "maxSampleRows": 200,
  "maxNormalizeRows": 2000000,
  "outcomePreference": [
    "w_av",
    "weighted_av",
    "wav",
    "car_av",
    "career_av",
    "dr_av",
    "drafted_av",
    "approximate_value",
    "av",
    "career_starts",
    "starts",
    "games_started",
    "games",
    "snaps"
  ],
  "hitThresholdPercentile": 0.6,
  "bustThresholdPercentile": 0.25,
  "notes": "dataDir is overridable via the DRAFTLENS_DATA_DIR env var or --data-dir CLI flag. The pipeline never writes to dataDir; it is read-only."
}
